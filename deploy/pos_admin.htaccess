# public_html/pos_admin/.htaccess
# Node must be running: npm run start  (PORT=8000 in .env or cPanel env)
# Upload latest index.js + utils/basePath.js after any code update, then restart Node.

RewriteEngine On

# Never expose server entry as a static download
RewriteRule ^index\.js$ - [F,L]

# Forward full URI to Node (app strips /pos_admin prefix internally)
RewriteCond %{REQUEST_URI} ^/pos_admin [NC]
RewriteRule ^ http://127.0.0.1:8000%{REQUEST_URI} [P,L,QSA]
