# Copy to: public_html/pos_admin/.htaccess
# Node on 127.0.0.1:8000 (pm2 or cPanel Node.js App)

RewriteEngine On
RewriteBase /pos_admin/

# Block downloading server source
RewriteRule ^index\.js$ - [F,L]

# IMPORTANT: strip /pos_admin before proxy — Node routes are /login/admin, /api/...
# (not /pos_admin/login/admin). Works with old and new app code.
RewriteRule ^(.*)$ http://127.0.0.1:8000/$1 [P,L,QSA]
