# local (default)
APP_ENV=development
MONGODB_URI=mongodb://localhost:27017/test

# live (Atlas) — set APP_ENV=live (or NODE_ENV=production)
MONGODB_URI_LIVE=mongodb+srv://<user>:<password>@cluster0.jok4qhf.mongodb.net/test?retryWrites=true&w=majority

# Redis — list cache (key: {companyId}:{module}:get-all-active[:q:hash])
# Local without Docker: install Redis in WSL2 — see scripts/WSL-REDIS.md
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
# Seconds (not ms). 259200 = 3 days. Used when REDIS_TTL_LIST_CACHE is unset.
REDIS_TTL_WAREHOUSE_ACTIVE=259200
REDIS_TTL_LIST_CACHE=1
REDIS_MEMORY_FALLBACK=true
# REDIS_ENABLED=false → cache lives only in this Node process; npm run dev restarts wipe it.
