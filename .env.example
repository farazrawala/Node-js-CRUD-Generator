# local (default)
APP_ENV=development
MONGODB_URI=mongodb://localhost:27017/test

# live (Atlas) — set APP_ENV=live (or NODE_ENV=production)
MONGODB_URI_LIVE=mongodb+srv://<user>:<password>@cluster0.jok4qhf.mongodb.net/test?retryWrites=true&w=majority

# Redis — warehouse get-all-active cache (key: {companyId}:warehouse:get-all-active, TTL 300s)
# Local without Docker: install Redis in WSL2 — see scripts/WSL-REDIS.md
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_TTL_WAREHOUSE_ACTIVE=300
REDIS_MEMORY_FALLBACK=true
