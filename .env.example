# local (default)
APP_ENV=development
MONGODB_URI=mongodb://localhost:27017/test

# Production URL (admin views, image URLs)
# BASE_URL=https://testv3.websitedemolynk.com/pos_admin
# Subdirectory deploy (Apache/cPanel proxy to Node on PORT)
# BASE_PATH=/pos_admin
# PORT=8000
# NODE_ENV=production

# live (Atlas) — set APP_ENV=live (or NODE_ENV=production)
MONGODB_URI_LIVE=mongodb+srv://<user>:<password>@cluster0.jok4qhf.mongodb.net/test?retryWrites=true&w=majority

# Redis — list cache (key: {companyId}:{module}:get-all-active|get-all[:q:hash])
# Local without Docker: install Redis in WSL2 — see scripts/WSL-REDIS.md
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
# Seconds (not ms). 259200 = 3 days. Used when REDIS_TTL_LIST_CACHE is unset.
REDIS_TTL_WAREHOUSE_ACTIVE=259200
REDIS_TTL_LIST_CACHE=1
REDIS_MEMORY_FALLBACK=true
# REDIS_ENABLED=false → cache lives only in this Node process; npm run dev restarts wipe it.

# Redis queues — tenant job queues (key: {companyId}:{module}:queue)
REDIS_QUEUE_ENABLED=true
REDIS_QUEUE_MEMORY_FALLBACK=true

# fetch_product: ?queue=1 on sync-store-product, or set true to always queue (skip inline sync)
FETCH_PRODUCT_AUTO_QUEUE=false

# Auto-run process queue: drain jobs batch-by-batch until finished
PROCESS_QUEUE_WORKER_ENABLED=true
PROCESS_QUEUE_WORKER_POLL_MS=10000
PROCESS_QUEUE_WORKER_BATCH_DELAY_MS=1000
PROCESS_QUEUE_WORKER_DEBOUNCE_MS=500
PROCESS_QUEUE_WORKER_MAX_BATCHES=5000
